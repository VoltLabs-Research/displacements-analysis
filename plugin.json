{
  "workflow": {
    "nodes": [
      {
        "id": "plugin-metadata",
        "type": "modifier",
        "position": {
          "x": 240,
          "y": 160
        },
        "data": {
          "modifier": {
            "name": "Displacements Analysis",
            "key": "displacements-analysis",
            "icon": "HiCube",
            "author": "Rodolfo Herrera",
            "license": "MIT",
            "version": "1.0.3",
            "homepage": "https://github.com/rodyherrera/Volterra",
            "description": ""
          }
        }
      },
      {
        "id": "plugin-arguments",
        "type": "arguments",
        "position": {
          "x": 528,
          "y": 208
        },
        "data": {
          "arguments": {
            "arguments": [
              {
                "argument": "reference",
                "type": "frame",
                "label": "Reference Frame"
              },
              {
                "argument": "mic",
                "type": "boolean",
                "label": "Minimum Image Convention",
                "default": true
              },
              {
                "argument": "affine_mapping",
                "type": "select",
                "label": "Affine Mapping",
                "default": "none",
                "options": [
                  {
                    "key": "none",
                    "label": "None"
                  },
                  {
                    "key": "toReference",
                    "label": "To Reference"
                  },
                  {
                    "key": "toCurrent",
                    "label": "To Current"
                  }
                ]
              }
            ]
          }
        }
      },
      {
        "id": "trajectory-context",
        "type": "context",
        "position": {
          "x": 816,
          "y": 160
        },
        "data": {
          "context": {
            "source": "trajectory_dumps"
          }
        }
      },
      {
        "id": "foreach-trajectory-dumps",
        "type": "forEach",
        "position": {
          "x": 1088,
          "y": 208
        },
        "data": {
          "forEach": {
            "iterableSource": "{{ trajectory-context.trajectory_dumps }}"
          }
        }
      },
      {
        "id": "analysis-entrypoint",
        "type": "entrypoint",
        "position": {
          "x": 1392,
          "y": 208
        },
        "data": {
          "entrypoint": {
            "type": "executable",
            "binary": "displacement-analysis",
            "binaryObjectPath": "__UPLOAD_BINARY_OBJECT_PATH__",
            "binaryFileName": "displacement-analysis",
            "arguments": "{{ foreach-trajectory-dumps.currentValue.path }} {{ foreach-trajectory-dumps.outputPath }} {{ plugin-arguments.as_str }}",
            "timeout": -1
          }
        }
      },
      {
        "id": "primary-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 208
        },
        "data": {
          "exposure": {
            "name": "Displacements",
            "icon": "HiCube",
            "results": "displacements.parquet",
            "iterable": ""
          }
        }
      },
      {
        "id": "displacements-model-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 336
        },
        "data": {
          "exposure": {
            "name": "Displacements Model",
            "icon": "HiCube",
            "results": "atoms.parquet",
            "iterable": ""
          }
        }
      },
      {
        "id": "displacements-model-export",
        "type": "export",
        "position": {
          "x": 2032,
          "y": 336
        },
        "data": {
          "export": {
            "exporter": "AtomisticExporter",
            "type": "glb"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "edge-metadata-arguments",
        "source": "plugin-metadata",
        "sourceHandle": "output",
        "target": "plugin-arguments",
        "targetHandle": "input"
      },
      {
        "id": "edge-arguments-context",
        "source": "plugin-arguments",
        "sourceHandle": "output",
        "target": "trajectory-context",
        "targetHandle": "input"
      },
      {
        "id": "edge-context-foreach",
        "source": "trajectory-context",
        "sourceHandle": "output",
        "target": "foreach-trajectory-dumps",
        "targetHandle": "input"
      },
      {
        "id": "edge-foreach-entrypoint",
        "source": "foreach-trajectory-dumps",
        "sourceHandle": "output",
        "target": "analysis-entrypoint",
        "targetHandle": "input"
      },
      {
        "id": "edge-entrypoint-exposure",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "primary-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-entrypoint-displacements-model-exposure",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "displacements-model-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-displacements-model-exposure-displacements-model-export",
        "source": "displacements-model-exposure",
        "sourceHandle": "output",
        "target": "displacements-model-export",
        "targetHandle": "input"
      }
    ]
  }
}
